              "sampleData": {},
              "sourceCode": {
                "code": "export const code = async (inputs) => {\n  // body_data is an object when AP parses application/json, a string for text/plain\n  // raw_body is the raw string fallback\n  let b = {};\n  for (const src of [inputs.body_data, inputs.raw_body]) {\n    if (!src) continue;\n    try {\n      const parsed = (typeof src === 'object') ? src : JSON.parse(src);\n      if (parsed && typeof parsed === 'object' && Object.keys(parsed).length > 0) {\n        b = parsed; break;\n      }\n    } catch(e) {}\n  }\n  const intentLabels = { 'now': 'Maintenant', '1-3months': \"D'ici 1 à 3 mois\", '3months+': 'Dans 3 mois et plus', 'curious': 'Juste curieux(se)' };\n  const firstName = (b.first_name || '').trim();\n  const lastName  = (b.last_name  || '').trim();\n  const intentLabel = intentLabels[b.intent] || b.intent || 'Non renseigné';\n  const rawEmail  = (b.email || '').trim();\n  const phone     = (b.phone || '').trim();\n  const emailTo   = rawEmail.includes('@') ? rawEmail : 'charles.alzon@gmail.com';\n  // Profil : particulier / professionnel\n  const isPro = (b.is_pro === true) || (b.profile === 'pro');\n  const profileLabel = isPro ? 'Professionnel' : 'Particulier';\n  const company = isPro ? ((b.company || '').trim() || 'Non renseigné') : '—';\n  return {\n    intent_raw: b.intent || '', intent_label: intentLabel,\n    first_name: firstName, last_name: lastName,\n    full_name: [firstName, lastName].filter(Boolean).join(' '),\n    email: rawEmail, email_to: emailTo, phone: phone,\n    profile: b.profile || (isPro ? 'pro' : 'particulier'),\n    is_pro: isPro, profile_label: profileLabel, company: company\n  };\n};",
                "packageJson": "{}"
              },
