                  "replyTo": "{{trigger['body']['email']}}",
                  "senderName": "Simulateur Balinaisa",
                  "subject": "🪵 Nouveau lead simulateur — {{trigger['body']['name']}} — {{step_2['product']}} ×{{step_2['qty']}}",
                  "body_type": "html",
                  "body": "<!DOCTYPE html><html><body style=\"font-family: Inter, Arial, sans-serif; background: #F3EFE9; padding: 32px; margin: 0;\">\n  <div style=\"max-width: 620px; margin: 0 auto; background: #ffffff; border-radius: 14px; overflow: hidden; box-shadow: 0 4px 20px rgba(0,0,0,0.08);\">\n\n    <!-- Header -->\n    <div style=\"background: #8B6B45; padding: 24px 32px; display: flex; align-items: center; justify-content: space-between;\">\n      <span style=\"font-size: 20px; font-weight: 700; color: #ffffff; letter-spacing: -0.02em;\">Balinaisa</span>\n      <span style=\"font-size: 12px; color: rgba(255,255,255,0.65); text-transform: uppercase; letter-spacing: 0.1em;\">Nouveau lead simulateur</span>\n    </div>\n\n    <!-- Body -->\n    <div style=\"padding: 32px;\">\n      <p style=\"margin: 0 0 8px; font-size: 22px; font-weight: 600; color: #1A1714;\">{{trigger['body']['name']}}</p>\n      <p style=\"margin: 0 0 28px; font-size: 14px; color: #9E9188;\">Demande reçue le {{step_1['date']}} à {{step_1['time']}} via le simulateur IA</p>\n\n      <!-- Contact info -->\n      <table style=\"width: 100%; border-collapse: collapse; margin-bottom: 24px;\">\n        <tr>\n          <td style=\"padding: 10px 0; border-bottom: 1px solid #E4DDD3; font-size: 12px; color: #9E9188; text-transform: uppercase; letter-spacing: 0.06em; width: 110px;\">Email</td>\n          <td style=\"padding: 10px 0; border-bottom: 1px solid #E4DDD3; font-size: 14px;\"><a href=\"mailto:{{trigger['body']['email']}}\" style=\"color: #8B6B45; text-decoration: none;\">{{trigger['body']['email']}}</a></td>\n        </tr>\n        <tr>\n          <td style=\"padding: 10px 0; border-bottom: 1px solid #E4DDD3; font-size: 12px; color: #9E9188; text-transform: uppercase; letter-spacing: 0.06em;\">Téléphone</td>\n          <td style=\"padding: 10px 0; border-bottom: 1px solid #E4DDD3; font-size: 14px; color: #1A1714;\">{{trigger['body']['phone']}}</td>\n        </tr>\n        <tr>\n          <td style=\"padding: 10px 0; border-bottom: 1px solid #E4DDD3; font-size: 12px; color: #9E9188; text-transform: uppercase; letter-spacing: 0.06em;\">Message</td>\n          <td style=\"padding: 10px 0; border-bottom: 1px solid #E4DDD3; font-size: 14px; color: #1A1714; line-height: 1.6;\">{{trigger['body']['message']}}</td>\n        </tr>\n      </table>\n\n      <!-- Devis simulateur -->\n      <div style=\"background: #FAF8F5; border: 1px solid #E4DDD3; border-radius: 10px; padding: 20px 24px; margin-bottom: 28px;\">\n        <p style=\"margin: 0 0 14px; font-size: 11px; font-weight: 600; color: #9E9188; text-transform: uppercase; letter-spacing: 0.08em;\">Devis simulateur</p>\n        <table style=\"width: 100%; border-collapse: collapse;\">\n          <tr>\n            <td style=\"padding: 6px 0; font-size: 14px; color: #6B6058;\">Produit</td>\n            <td style=\"padding: 6px 0; font-size: 14px; font-weight: 600; color: #1A1714; text-align: right;\">{{step_2['product']}}</td>\n          </tr>\n          <tr>\n            <td style=\"padding: 6px 0; font-size: 14px; color: #6B6058;\">Quantité</td>\n            <td style=\"padding: 6px 0; font-size: 14px; font-weight: 600; color: #1A1714; text-align: right;\">{{step_2['qty']}}</td>\n          </tr>\n          <tr>\n            <td style=\"padding: 6px 0; font-size: 14px; color: #6B6058;\">Prix unitaire HT</td>\n            <td style=\"padding: 6px 0; font-size: 14px; color: #1A1714; text-align: right;\">{{step_2['unit_price_ht']}}</td>\n          </tr>\n          <tr>\n            <td style=\"padding: 6px 0; font-size: 14px; color: #6B6058;\">Total HT</td>\n            <td style=\"padding: 6px 0; font-size: 14px; color: #1A1714; text-align: right;\">{{step_2['total_ht']}}</td>\n          </tr>\n          <tr>\n            <td style=\"padding: 6px 0; font-size: 14px; color: #6B6058;\">TVA 20%</td>\n            <td style=\"padding: 6px 0; font-size: 14px; color: #1A1714; text-align: right;\">{{step_2['tva']}}</td>\n          </tr>\n          <tr style=\"border-top: 2px solid #E4DDD3;\">\n            <td style=\"padding: 10px 0 6px; font-size: 15px; font-weight: 700; color: #1A1714;\">Total TTC</td>\n            <td style=\"padding: 10px 0 6px; font-size: 16px; font-weight: 700; color: #8B6B45; text-align: right;\">{{step_2['total_ttc']}}</td>\n          </tr>\n        </table>\n        {{#if step_2['has_discount']}}\n        <p style=\"margin: 10px 0 0; font-size: 12px; color: #3D7A5A;\">✓ {{step_2['discount_label']}}</p>\n        {{/if}}\n      </div>\n\n      <!-- CTA -->\n      <a href=\"mailto:{{trigger['body']['email']}}?subject=Votre devis Balinaisa — {{step_2['product']}} ×{{step_2['qty']}}&body=Bonjour {{trigger['body']['name']}},%0A%0AMerci pour votre simulation...\" style=\"display: inline-block; background: #8B6B45; color: #ffffff; padding: 13px 24px; border-radius: 8px; text-decoration: none; font-size: 14px; font-weight: 600;\">Répondre à {{trigger['body']['name']}} →</a>\n    </div>\n\n    <!-- Footer -->\n    <div style=\"background: #FAF8F5; padding: 14px 32px; border-top: 1px solid #E4DDD3;\">\n      <p style=\"margin: 0; font-size: 12px; color: #9E9188;\">Lead enregistré dans Google Sheets · Simulateur propulsé par <a href=\"https://paktiz.fr\" style=\"color: #8B6B45; text-decoration: none;\">Paktiz</a></p>\n    </div>\n  </div>\n</body></html>",
                  "attachments": [],
                  "customHeaders": {}
