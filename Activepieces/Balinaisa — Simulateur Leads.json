                  "code": "export const code = async (inputs) => {\n  // PLACEHOLDER V1 — remplacer par appel Vertex AI Imagen 3\n  // Inputs: photo_base64 (data URL), product_id, product_name\n  // Output attendu: image_url (URL publique de l'image g\\u00e9n\\u00e9r\\u00e9e)\n  //\n  // Pour brancher l'IA :\n  //   1. Appel HTTP POST Vertex AI avec photo_base64 + product prompt\n  //   2. Upload r\\u00e9sultat vers Cloudinary / Google Cloud Storage / ImgBB\n  //   3. Retourner l'URL publique dans image_url\n\n  const productName = encodeURIComponent(inputs.product_name || 'Balinaisa');\n  const imageUrl = `https://placehold.co/560x360/F2ECE3/B87D4B/png?text=${productName}+%E2%80%94+simulation+en+pr%C3%A9paration`;\n\n  return {\n    image_url: imageUrl,\n    status: 'placeholder_v1'\n  };\n};",
