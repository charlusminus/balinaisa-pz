                  "code": "export const code = async (inputs) => {\n  // PLACEHOLDER V1 — remplacer par appel Vertex AI Imagen 3\n  // L'IA fait la reco complète : à partir de la photo (photo_base64),\n  // elle sélectionne le mobilier d'extérieur en teck Balinaisa adapté\n  // et l'intègre à la scène. Plus de produit choisi en amont.\n  //\n  // Pour brancher l'IA :\n  //   1. Appel HTTP POST Vertex AI avec photo_base64 + prompt de reco Balinaisa\n  //   2. Upload résultat vers Cloudinary / Google Cloud Storage / ImgBB\n  //   3. Retourner l'URL publique dans image_url\n\n  const imageUrl = `https://placehold.co/560x360/F2ECE3/B87D4B/png?text=Balinaisa+%E2%80%94+simulation+en+pr%C3%A9paration`;\n\n  return {\n    image_url: imageUrl,\n    status: 'placeholder_v1'\n  };\n};",
