          "valid": true,
          "displayName": "Formater date et heure de réception",
          "lastUpdatedDate": "2026-06-22T00:00:00.000Z",
          "settings": {
            "input": {},
            "sampleData": {},
            "sourceCode": {
              "code": "export const code = async (inputs) => {\n  const now = new Date();\n  const pad = (n) => String(n).padStart(2, '0');\n  const date = `${pad(now.getDate())}/${pad(now.getMonth() + 1)}/${now.getFullYear()}`;\n  const time = `${pad(now.getHours())}:${pad(now.getMinutes())}`;\n  return {\n    date,\n    time,\n    datetime: `${date} ${time}`,\n    iso: now.toISOString()\n  };\n};",
              "packageJson": "{}"
            },
            "errorHandlingOptions": {
              "retryOnFailure": { "value": false },
              "continueOnFailure": { "value": true }
            }
          },
          "nextAction": {
            "name": "step_2",
            "skip": false,
            "type": "CODE",
            "valid": true,
            "displayName": "Calculer le devis",
            "lastUpdatedDate": "2026-06-22T00:00:00.000Z",
            "settings": {
              "input": {
                "product": "{{trigger['body']['product']}}",
                "qty": "{{trigger['body']['qty']}}",
                "price_ttc": "{{trigger['body']['price_ttc']}}"
              },
              "sampleData": {},
              "sourceCode": {
                "code": "export const code = async (inputs) => {\n  const qty = parseInt(inputs.qty) || 1;\n  const priceTTC = parseFloat(inputs.price_ttc) || 0;\n  const priceHT = priceTTC / 1.2;\n  const tva = priceTTC - priceHT;\n  const unitPriceHT = priceHT / qty;\n  const hasDiscount = qty >= 4;\n  const fmt = (n) => n.toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' €';\n  return {\n    qty,\n    product: inputs.product || 'N/A',\n    unit_price_ht: fmt(unitPriceHT),\n    total_ht: fmt(priceHT),\n    tva: fmt(tva),\n    total_ttc: fmt(priceTTC),\n    has_discount: hasDiscount,\n    discount_label: hasDiscount ? 'Remise pack ×4 appliquée (−10%)' : ''\n  };\n};",
                "packageJson": "{}"
              },
              "errorHandlingOptions": {
                "retryOnFailure": { "value": false },
                "continueOnFailure": { "value": true }
              }
            },
            "nextAction": {
              "name": "step_3",
              "skip": false,
              "type": "PIECE",
              "valid": true,
              "displayName": "Notifier Balinaisa — nouveau lead simulateur",
              "lastUpdatedDate": "2026-06-22T00:00:00.000Z",
              "settings": {
                "pieceName": "@activepieces/piece-smtp",
                "actionName": "send-email",
                "pieceVersion": "0.3.12",
                "sampleData": {},
                "input": {
                  "auth": "{{connections['KjJDiOyNMh3TXw8HF9VFz']}}",
