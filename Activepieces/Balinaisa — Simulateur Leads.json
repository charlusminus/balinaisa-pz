              "sampleData": {},
              "sourceCode": {
                "code": "export const code = async (inputs) => {\n  const qty = parseInt(inputs.qty) || 1;\n  const unitPriceHT = parseFloat(inputs.product_price_ht) || 0;\n  const hasDiscount = qty >= 4;\n  const totalHTBefore = unitPriceHT * qty;\n  const discountAmt = hasDiscount ? totalHTBefore * 0.10 : 0;\n  const totalHT = totalHTBefore - discountAmt;\n  const tva = totalHT * 0.20;\n  const totalTTC = totalHT + tva;\n  const fmt = (n) => n.toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' €';\n  const intentLabels = {\n    'now': 'Maintenant',\n    '1-3months': \"D'ici 1 à 3 mois\",\n    '3months+': 'Dans 3 mois et plus',\n    'curious': 'Juste curieux(se)'\n  };\n  const firstName = (inputs.first_name || '').trim();\n  const lastName = (inputs.last_name || '').trim();\n  return {\n    qty,\n    product: inputs.product || 'N/A',\n    product_id: inputs.product_id || '',\n    unit_price_ht: fmt(unitPriceHT),\n    total_ht: fmt(totalHT),\n    tva: fmt(tva),\n    total_ttc: fmt(totalTTC),\n    has_discount: hasDiscount,\n    discount_label: hasDiscount ? 'Remise pack ×4 appliquée (−10%)' : '',\n    intent_raw: inputs.intent || '',\n    intent_label: intentLabels[inputs.intent] || inputs.intent || 'Non renseigné',\n    first_name: firstName,\n    last_name: lastName,\n    full_name: [firstName, lastName].filter(Boolean).join(' ')\n  };\n};",
                "packageJson": "{}"
