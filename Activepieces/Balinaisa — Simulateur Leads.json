              },
              "sampleData": {},
              "sourceCode": {
                "code": "export const code = async (inputs) => {\n  const qty = parseInt(inputs.qty) || 1;\n  const unitPriceHT = parseFloat(inputs.product_price_ht) || 0;\n  const hasDiscount = qty >= 4;\n  const totalHTBefore = unitPriceHT * qty;\n  const discountAmt = hasDiscount ? totalHTBefore * 0.10 : 0;\n  const totalHT = totalHTBefore - discountAmt;\n  const tva = totalHT * 0.20;\n  const totalTTC = totalHT + tva;\n  const fmt = (n) => n.toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' \\u20ac';\n  const intentLabels = { 'now': 'Maintenant', '1-3months': \"D'ici 1 \\u00e0 3 mois\", '3months+': 'Dans 3 mois et plus', 'curious': 'Juste curieux(se)' };\n  const firstName = (inputs.first_name || '').trim();\n  const lastName = (inputs.last_name || '').trim();\n  const intentLabel = intentLabels[inputs.intent] || inputs.intent || 'Non renseign\\u00e9';\n  const product = inputs.product || 'N/A';\n  const productId = inputs.product_id || '';\n  return {\n    qty, product, product_id: productId,\n    unit_price_ht: fmt(unitPriceHT), total_ht: fmt(totalHT), tva: fmt(tva), total_ttc: fmt(totalTTC),\n    has_discount: hasDiscount,\n    discount_label: hasDiscount ? 'Remise pack \\u00d74 appliqu\\u00e9e (\\u221210%)' : '',\n    intent_raw: inputs.intent || '', intent_label: intentLabel,\n    first_name: firstName, last_name: lastName,\n    full_name: [firstName, lastName].filter(Boolean).join(' ')\n  };\n};",
                "packageJson": "{}"
